{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceName": "mvp-demo-service",
  "ServiceVersion": "1.0.0",
  "Otel": {
    "OtlpEndpoint": "http://localhost:4317",
    "OtlpHttpEndpoint": "http://localhost:4318",
    "EnableRedis": true,
    "EnableGrpc": true,
    "EnableMongo": true,
    "EnableMassTransit": true,
    "EnableQuartz": true
  },
  "ConnectionStrings": {
    "Redis": "redis:6379",
    "Mongo": "mongodb://mongo:27017"
  }
}
